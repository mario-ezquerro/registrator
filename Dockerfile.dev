FROM golang:1.17.1-alpine3.14

# Instalar dependencias del sistema necesarias
RUN apk add --no-cache bash git ca-certificates tzdata

WORKDIR /go/src/github.com/mario-ezquerro/registrator/

# Cachear módulos de go por separado
COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Compilar para entorno de desarrollo (sin optimizaciones de release)
RUN go build -ldflags "-X main.Version=dev" -o /bin/registrator .

CMD ["/bin/registrator"]
